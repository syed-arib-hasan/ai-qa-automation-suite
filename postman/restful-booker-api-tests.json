    {
      "name": "Get Specific Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Booking has correct guest name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.firstname).to.eql(\"John\");\r",
              "    pm.expect(jsonData.lastname).to.eql(\"Doe\");\r",
              "});\r",
              "\r",
              "pm.test(\"Booking has correct dates\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.bookingdates.checkin).to.eql(\"2026-07-01\");\r",
              "    pm.expect(jsonData.bookingdates.checkout).to.eql(\"2026-07-05\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{newBookingId}}",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking",
            "{{newBookingId}}"
          ]
        }
      },
      "response": []
    },
    {
