              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{newBookingId}}",
          "protocol": "https",
          "host": [
            "restful-booker",
